<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Parcel Ops Daily Scorecard — {{ data_date_short }}</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%23FF3008'/%3E%3Cpath d='M8 12l8-5 8 5v10l-8 5-8-5z' fill='none' stroke='white' stroke-width='2' stroke-linejoin='round'/%3E%3Cpath d='M16 17v10M8 12l8 5 8-5' fill='none' stroke='white' stroke-width='2' stroke-linejoin='round'/%3E%3C/svg%3E">
<style>
  :root {
    --bg: #0f1117; --surface: #161923; --card: #1c2030; --border: #272d42;
    --text: #e2e4ef; --dim: #7b82a0; --accent: #6c8cff;
    --green: #34d399; --yellow: #fbbf24; --red: #f87171; --orange: #fb923c;
    --purple: #a78bfa; --blue: #60a5fa; --teal: #2dd4bf;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, sans-serif; background: var(--bg); color: var(--text); }

  .topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 1.25rem 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: .75rem; }
  .topbar h1 { font-size: 1.25rem; font-weight: 700; letter-spacing: -.01em; }
  .topbar .meta { font-size: .78rem; color: var(--dim); }
  .sources { display: flex; gap: .4rem; flex-wrap: wrap; }
  .src { font-size: .62rem; padding: .15rem .5rem; border-radius: 999px; border: 1px solid var(--border); color: var(--dim); text-transform: uppercase; letter-spacing: .04em; }
  .src.active { border-color: var(--green); color: var(--green); }
  .src.warn { border-color: var(--yellow); color: var(--yellow); }
  .src.na { border-color: var(--border); color: var(--dim); opacity: .5; }

  .kpi-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: .75rem; padding: 1rem 2rem; background: var(--surface); border-bottom: 1px solid var(--border); }
  .kpi { background: var(--card); border: 1px solid var(--border); border-radius: .6rem; padding: .75rem 1rem; display: flex; flex-direction: column; }
  .kpi .label { font-size: .62rem; text-transform: uppercase; letter-spacing: .05em; color: var(--dim); margin-bottom: .2rem; }
  .kpi .val { font-size: 1.3rem; font-weight: 800; }
  .kpi .sub { font-size: .68rem; color: var(--dim); flex-grow: 1; }
  .kpi .trend { font-size: .65rem; margin-top: auto; padding-top: .35rem; font-weight: 600; }
  .kpi .trend.up { color: var(--green); }
  .kpi .trend.down { color: var(--red); }
  .kpi .trend.neutral { color: var(--dim); }

  .section { padding: 1rem 2rem .5rem; }
  .section-head { display: flex; align-items: center; gap: .6rem; margin-bottom: .5rem; }
  .section-head h2 { font-size: 1rem; font-weight: 700; }
  .badge { font-size: .58rem; padding: .12rem .45rem; border-radius: 999px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; }
  .badge-hub { background: rgba(108,140,255,.15); color: var(--accent); }
  .badge-spoke { background: rgba(167,139,250,.15); color: var(--purple); }

  table { width: 100%; border-collapse: collapse; font-size: .78rem; }
  thead th { text-align: left; padding: .5rem .6rem; font-size: .62rem; text-transform: uppercase; letter-spacing: .05em; color: var(--dim); border-bottom: 2px solid var(--border); position: sticky; top: 0; background: var(--bg); z-index: 2; }
  tbody td { padding: .55rem .6rem; border-bottom: 1px solid var(--border); vertical-align: top; line-height: 1.45; }
  tbody tr:hover { background: rgba(108,140,255,.04); }
  .site-col { font-weight: 700; font-size: .85rem; white-space: nowrap; min-width: 65px; }

  .tag { display: inline-block; font-size: .6rem; font-weight: 700; padding: .1rem .35rem; border-radius: .25rem; margin-right: .25rem; text-transform: uppercase; letter-spacing: .03em; vertical-align: middle; }
  .tag-p1 { background: rgba(248,113,113,.15); color: var(--red); }
  .tag-tdd { background: rgba(167,139,250,.15); color: var(--purple); }
  .tag-eos { background: rgba(52,211,153,.15); color: var(--green); }
  .tag-new { background: rgba(52,211,153,.15); color: var(--green); }
  .tag-alert { background: rgba(248,113,113,.2); color: var(--red); }

  .eos-ok { color: var(--green); }
  .eos-miss { color: var(--red); font-weight: 600; }
  .clean { color: var(--dim); font-style: italic; }
  .pending-text { color: var(--yellow); font-style: italic; }

  .footer { text-align: center; padding: 1.5rem; color: var(--dim); font-size: .7rem; border-top: 1px solid var(--border); margin-top: 1rem; }

  @media (max-width: 900px) { .topbar, .kpi-row, .section { padding-left: .75rem; padding-right: .75rem; } }
  @media print {
    body { background: #fff; color: #1a1a1a; }
    .topbar, .kpi-row, .section { background: #fff; }
    table, th, td { border-color: #ddd; }
    .kpi { background: #f5f5f5; border-color: #ddd; }
  }
</style>
</head>
<body>

<div class="topbar">
  <div style="display:flex; align-items:center; gap:.75rem;">
    <img src="https://static.cdnlogo.com/logos/d/89/doordash.svg" alt="DoorDash" style="height:14px; filter:none;" onerror="this.src='https://logo.svgcdn.com/simple-icons/doordash-dark.svg'; this.style.filter='none'; this.onerror=null;">
    <div>
    <h1>Parcel Core Ops &mdash; Daily Site Review</h1>
    <div class="meta">Operational Day: {{ op_date_long }} &nbsp;|&nbsp; {{ hub_count }} Hubs &middot; {{ spoke_count }} Spokes &nbsp;|&nbsp; Generated {{ generated_date }}</div>
    </div>
  </div>
  <div class="sources">
    {% for src in sources %}
    <span class="src {{ src.status }}">{{ src.label }}</span>
    {% endfor %}
  </div>
</div>

<div class="kpi-row">
  {% for kpi in kpis %}
  <div class="kpi"><div class="label">{{ kpi.label }}</div><div class="val" style="color:{{ kpi.color }}">{{ kpi.value }}</div><div class="sub">{{ kpi.sub }}</div><div class="trend {{ kpi.trend_class }}">{{ kpi.trend_text }}</div></div>
  {% endfor %}
</div>

<div class="section" style="margin-top:1.2rem; margin-bottom:0;">
  <div class="section-head">
    <h2>📋 Operations Summary &mdash; {{ data_date_short }}</h2>
  </div>
  <div style="background:var(--card); border:1px solid var(--border); border-radius:10px; padding:1rem 1.4rem; font-size:.85rem; line-height:1.7; color:var(--text);">
    {{ ops_summary }}
  </div>
</div>

<!-- ═══════════ HUBS ═══════════ -->
<div class="section">
  <div class="section-head">
    <h2>🚛 Hubs</h2>
    <span class="badge badge-hub">{{ hubs|length }} Sites</span>
  </div>
  <table>
    <thead>
      <tr>
        <th style="width:70px">Site</th>
        <th style="width:90px">Sort Partner</th>
        <th style="width:85px; text-align:center">Forecast Vol</th>
        <th style="width:85px; text-align:center">Scanned Vol</th>
        <th style="width:70px; text-align:center">% Var</th>
        <th style="width:80px; text-align:center">OB CPT %</th>
        <th style="width:115px">EOS Report</th>
        <th>EOS Notes</th>
        <th>#ask-parcels Tickets</th>
        <th>LiveOps Tracker</th>
      </tr>
    </thead>
    <tbody>
      {% for hub in hubs %}
      <tr>
        <td class="site-col">{{ hub.name }}{% if hub.escalation %} <span class="tag tag-alert">⚠ ESCALATION</span>{% endif %}{% for tag in hub.tags %} {{ tag }}{% endfor %}</td>
        <td>{{ hub.sort_partner }}</td>
        <td style="text-align:center">{{ hub.forecast_vol }}</td>
        <td style="text-align:center">{{ hub.scanned_vol }}</td>
        <td style="text-align:center"><span style="color:{{ hub.var_color }}">{{ hub.var_pct }}</span></td>
        <td style="text-align:center"><span style="color:{{ hub.cpt_color }}">{{ hub.cpt_pct }}</span></td>
        <td class="eos-{{ hub.eos_status }}">{% if hub.eos_status == 'ok' %}Received{% else %}Missing{% endif %}</td>
        <td>{{ hub.eos_notes }}</td>
        <td>{{ hub.tickets }}</td>
        <td>{{ hub.liveops }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<!-- ═══════════ SPOKES ═══════════ -->
<div class="section">
  <div class="section-head">
    <h2>🚗 Spokes</h2>
    <span class="badge badge-spoke">{{ spokes|length }} Sites</span>
  </div>
  <table>
    <thead>
      <tr>
        <th style="width:70px">Site</th>
        <th style="width:90px">Sort Partner</th>
        <th style="width:85px; text-align:center">Forecast Vol</th>
        <th style="width:85px; text-align:center">Scanned Vol</th>
        <th style="width:70px; text-align:center">% Var</th>
        <th style="width:100px; text-align:center">OTD Miss Attrib.</th>
        <th>#ask-parcels Tickets</th>
        <th>Staples TDD Callouts</th>
        <th>LiveOps Tracker</th>
      </tr>
    </thead>
    <tbody>
      {% for spoke in spokes %}
      <tr>
        <td class="site-col">{{ spoke.name }}</td>
        <td>{{ spoke.sort_partner }}</td>
        <td style="text-align:center">{{ spoke.forecast_vol }}</td>
        <td style="text-align:center">{{ spoke.scanned_vol }}</td>
        <td style="text-align:center"><span style="color:{{ spoke.var_color }}">{{ spoke.var_pct }}</span></td>
        <td style="text-align:center"><span style="color:{{ spoke.otd_miss_color }}">{{ spoke.otd_miss_pct }}</span></td>
        <td>{{ spoke.tickets }}</td>
        <td>{{ spoke.tdd_callouts }}</td>
        <td>{{ spoke.liveops }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<div class="footer">
  {{ footer_text }}
</div>

</body>
</html>
